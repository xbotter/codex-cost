{
  "name": "codex-cost",
  "private": false,
  "version": "0.19.0",
  "description": "A cross-platform Tauri tray app that estimates daily Codex cost from local usage logs.",
  "license": "MIT",
  "author": "xbotter",
  "homepage": "https://github.com/xbotter/codex-cost#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xbotter/codex-cost.git"
  },
  "bugs": {
    "url": "https://github.com/xbotter/codex-cost/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check:contracts": "node --test tests/view-contract.test.mjs tests/provider-switch-contract.test.mjs tests/quota-layout-contract.test.mjs",
    "check:frontend": "tsc && vite build",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "fmt:rust": "cargo fmt --all --manifest-path src-tauri/Cargo.toml --check",
    "check": "npm run check:contracts && npm run check:frontend && npm run fmt:rust && npm run check:rust",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource/nunito": "^5.2.7",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "html-to-image": "^1.11.13",
    "lucide-static": "^0.577.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "typescript": "~5.9.3",
    "vite": "^6.0.3"
  }
}
